---
---

<canvas id="confetti-canvas"></canvas>

<style>
  #confetti-canvas {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
</style>

<script>
  const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  let W: number;
  let H: number;

  interface Piece {
    x: number; y: number; r: number; c: string;
    rot: number; vx: number; vy: number; vr: number;
    shape: 'rect' | 'circle'; w: number; h: number; opacity: number;
  }

  let pieces: Piece[] = [];

  const COLORS = ['#ff4f7b', '#f7c948', '#c084fc', '#60d4f7', '#ff8fab', '#fff8f0', '#a78bfa'];

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  function mkPiece(): Piece {
    return {
      x:       Math.random() * W,
      y:       -20,
      r:       Math.random() * 5 + 2,
      c:       COLORS[Math.floor(Math.random() * COLORS.length)],
      rot:     Math.random() * Math.PI * 2,
      vx:      (Math.random() - 0.5) * 1.2,
      vy:      Math.random() * 2 + 0.8,
      vr:      (Math.random() - 0.5) * 0.12,
      shape:   Math.random() > 0.5 ? 'rect' : 'circle',
      w:       Math.random() * 8 + 4,
      h:       Math.random() * 5 + 2,
      opacity: Math.random() * 0.5 + 0.5,
    };
  }

  function burst(x: number, y: number, count = 30) {
    for (let i = 0; i < count; i++) {
      const p = mkPiece();
      p.x  = x;
      p.y  = y;
      p.vx = (Math.random() - 0.5) * 6;
      p.vy = (Math.random() - 0.5) * 6;
      pieces.push(p);
    }
  }

  function loop() {
    ctx.clearRect(0, 0, W, H);

    if (pieces.length < 260) pieces.push(mkPiece());

    for (let i = pieces.length - 1; i >= 0; i--) {
      const p = pieces[i];
      p.x   += p.vx;
      p.y   += p.vy;
      p.rot += p.vr;

      ctx.save();
      ctx.globalAlpha = p.opacity;
      ctx.fillStyle   = p.c;
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rot);

      if (p.shape === 'rect') {
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
      } else {
        ctx.beginPath();
        ctx.arc(0, 0, p.r, 0, Math.PI * 2);
        ctx.fill();
      }

      ctx.restore();

      if (p.y > H + 30) pieces.splice(i, 1);
    }

    requestAnimationFrame(loop);
  }

  // init
  resize();
  window.addEventListener('resize', resize);

  // initial burst spread across screen
  for (let i = 0; i < 140; i++) {
    const p = mkPiece();
    p.y = Math.random() * H;
    pieces.push(p);
  }

  loop();

  // click burst — exposed so other components can reuse
  document.addEventListener('click', (e) => burst(e.clientX, e.clientY));
</script>
